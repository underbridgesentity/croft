# node_modules is ignored EXCEPT the four Capacitor iOS plugin packages -
# they are local Swift packages the Xcode project needs, and Xcode Cloud
# runners can't npm-install them (no network in custom build phases).
node_modules/*
!node_modules/@capacitor
node_modules/@capacitor/*
!node_modules/@capacitor/app
!node_modules/@capacitor/haptics
!node_modules/@capacitor/push-notifications
!node_modules/@capacitor/share
# nested workspace node_modules stay fully ignored
*/node_modules/
**/xcuserdata/
dist/
.env
.env.local
server/.env
web/dist/
.pgdata/
*.log
.DS_Store
dev.db
.shots/
.vercel

# Capacitor / iOS native build artifacts (generated on a Mac via `npx cap add ios`)
ios/App/Pods/
# ios/App/App/public is COMMITTED (regenerated by `npx cap sync`): Xcode Cloud
# can't build web/dist itself, so the copied assets must be in the repo.
ios/App/build/
ios/DerivedData/
*.xcuserstate
.gradle/
