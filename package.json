{
  "name": "croft",
  "version": "1.0.0",
  "private": true,
  "description": "Croft — one calm home for your whole family. Mobile PWA + Node/Neon backend.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "start": "npm run start --workspace server",
    "db:setup": "npm run db:setup --workspace server",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:add:ios": "npx cap add ios",
    "cap:open:ios": "npx cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "concurrently": "^9.1.2",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.6.2"
  }
}
